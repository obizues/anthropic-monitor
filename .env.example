# ── Claude API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (transactional email) ─────────────────────────────────────────────
# Sign up free at https://resend.com — no domain required to get started
RESEND_API_KEY=re_...
# Use "onboarding@resend.dev" for testing, or "Alerts <alerts@yourdomain.com>" once you verify a domain
RESEND_FROM_ADDRESS=Anthropic Monitor <onboarding@resend.dev>

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
UNSUBSCRIBE_SECRET=changeme-generate-a-real-secret
CONFIG_API_KEY=changeme-generate-a-real-api-key

# ── Admin alerts (self-monitoring) ───────────────────────────────────────────
ADMIN_EMAIL=you@yourcompany.com
